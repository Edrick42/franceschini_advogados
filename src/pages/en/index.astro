---
import Layout from "~/layouts/Layout.astro";
import Hero from "~/components/Hero.astro";
import Section from "~/components/Section.astro";
import Button from "~/components/Button.astro";
import { getCollection } from "astro:content";
import site from "~/data/site.json";
import { t } from "~/i18n/utils";

const locale = "en";
const dict = t(locale);

const areas = (await getCollection("practice-areas")).sort(
  (a, b) => a.data.order - b.data.order,
);

const teamMembers = (await getCollection("team")).sort(
  (a, b) => a.data.order - b.data.order,
);

const allArticles = (await getCollection("articles-en", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});

const categoryLabel: Record<string, string> = dict.publications.categories;
---

<Layout title={undefined} description={site.description.en}>
  <Hero
    eyebrow={dict.home.eyebrow}
    heading={dict.home.heading}
    lede={dict.home.lede}
    ctaPrimary={{ label: dict.home.ctaPrimary, href: site.primaryCta.en.href }}
    ctaSecondary={{ label: dict.home.ctaSecondary, href: "/en/firm" }}
  />

  <Section>
    <div class="section-intro">
      <p class="eyebrow">{dict.home.areasHeading}</p>
      <h2 class="section-intro__heading">{dict.home.areasLede}</h2>
    </div>

    <ul class="areas">
      {
        areas.map((area, i) => (
          <li class="areas__item">
            <span class="areas__index" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="areas__body">
              <h3 class="areas__name">{area.data.name.en}</h3>
              <p class="areas__summary">{area.data.summary.en}</p>
            </div>
            <a class="areas__cta" href={`/en/practice#${area.data.slug}`}>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="section-cta">
      <Button href="/en/practice" variant="ghost">{dict.home.areasCta}</Button>
    </div>
  </Section>

  <Section variant="surface">
    <div class="lead-grid">
      <div class="lead-grid__col-label">
        <p class="eyebrow">{dict.home.teamHeading}</p>
      </div>
      <div class="lead-grid__col-body">
        <h2 class="lead-grid__heading">{dict.home.teamLede}</h2>
      </div>
    </div>

    <ul class="team-grid">
      {
        teamMembers.map((member) => (
          <li class="team-card">
            <div class="team-card__photo">
              {member.data.photo ? (
                <img src={member.data.photo} alt={member.data.name} loading="lazy" decoding="async" />
              ) : (
                <span aria-hidden="true">
                  {member.data.name.split(" ")[0][0]}
                  {member.data.name.split(" ").slice(-1)[0][0]}
                </span>
              )}
            </div>
            <div class="team-card__body">
              <p class="team-card__role">{member.data.role.en}</p>
              <h3 class="team-card__name">{member.data.name}</h3>
              <p class="team-card__bio">{member.data.bio.en}</p>
            </div>
          </li>
        ))
      }
    </ul>

    <div class="section-cta">
      <Button href="/en/team" variant="ghost">{dict.home.teamCta}</Button>
    </div>
  </Section>

  <Section>
    <div class="lead-grid">
      <div class="lead-grid__col-label">
        <p class="eyebrow">{dict.home.publicationsHeading}</p>
      </div>
      <div class="lead-grid__col-body">
        <h2 class="lead-grid__heading">{dict.home.publicationsLede}</h2>
      </div>
    </div>

    {
      allArticles.length > 0 ? (
        <ul class="articles">
          {allArticles.map((article) => (
            <li class="article-card">
              <a href={`/en/publications/${article.id.replace(/\.md$/, "")}`} class="article-card__link">
                <p class="article-card__meta">
                  <span class="article-card__category">
                    {categoryLabel[article.data.category]}
                  </span>
                  <time datetime={article.data.date.toISOString()}>
                    {dateFormatter.format(article.data.date)}
                  </time>
                </p>
                <h3 class="article-card__title">{article.data.title}</h3>
                <p class="article-card__description">{article.data.description}</p>
                <span class="article-card__read">{dict.publications.readMore} →</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">{dict.publications.empty}</p>
      )
    }

    <div class="section-cta">
      <Button href="/en/publications" variant="ghost">{dict.home.publicationsCta}</Button>
    </div>
  </Section>

  <Section variant="soft" size="lg">
    <div class="closing">
      <h2 class="closing__heading">{dict.home.closingHeading}</h2>
      <p class="closing__lede">{dict.home.closingLede}</p>
      <div class="closing__cta">
        <Button href="/en/contact" variant="primary">{dict.home.ctaPrimary}</Button>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .lead-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }
  @media (min-width: 768px) {
    .lead-grid {
      grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
      gap: var(--space-7);
      align-items: baseline;
    }
  }
  .lead-grid__heading {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-strong);
    max-width: 32ch;
    text-wrap: balance;
  }
  .section-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }
  .section-intro__heading {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-strong);
    max-width: 32ch;
    text-wrap: balance;
  }
  .section-cta {
    margin-top: var(--space-7);
    display: flex;
    justify-content: flex-end;
  }

  .areas {
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }
  .areas__item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
    transition: padding var(--duration-fast) var(--ease-out);
  }
  .areas__item:hover {
    padding-left: var(--space-3);
  }
  .areas__index {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--color-highlight);
    min-width: 3ch;
    letter-spacing: var(--tracking-tight);
  }
  .areas__name {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    color: var(--color-text-strong);
    line-height: 1.15;
    margin-bottom: var(--space-2);
  }
  .areas__summary {
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .areas__cta {
    color: var(--color-text-muted);
    font-size: var(--text-2xl);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .areas__cta:hover {
    background: var(--color-highlight-soft);
    color: var(--color-text-strong);
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .team-card__photo {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(42, 41, 38, 0.86), rgba(26, 26, 23, 0.94)),
      url("/patterns/pattern-1.webp");
    background-size: cover;
    color: var(--color-text-inverse);
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
  }
  .team-card__photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }
  .team-card__photo span {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .team-card__role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .team-card__name {
    font-family: var(--font-display);
    font-size: clamp(var(--text-xl), 2.4vw, var(--text-2xl));
    font-weight: var(--weight-regular);
    color: var(--color-text-strong);
    margin-block: var(--space-2);
    line-height: 1.15;
  }
  .team-card__bio {
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .articles {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 800px) {
    .articles {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .article-card__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    height: 100%;
    transition: border-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .article-card__link:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
  }
  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .article-card__category {
    color: var(--color-highlight-strong);
    font-weight: var(--weight-medium);
  }
  .article-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    line-height: 1.2;
    color: var(--color-text-strong);
  }
  .article-card__description {
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .article-card__read {
    margin-top: auto;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-strong);
  }
  .empty {
    color: var(--color-text-muted);
    text-align: center;
    padding-block: var(--space-8);
    font-style: italic;
  }

  .closing {
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .closing__heading {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: clamp(var(--text-4xl), 5vw, var(--text-6xl));
    line-height: 1.05;
    letter-spacing: var(--tracking-tighter);
    color: var(--brand-onix);
  }
  .closing__lede {
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    color: var(--color-text-muted);
  }
  .closing__cta {
    margin-top: var(--space-4);
  }
</style>
