---
import Layout from "~/layouts/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Section from "~/components/Section.astro";
import Button from "~/components/Button.astro";
import { t } from "~/i18n/utils";
const dict = t("en");
---

<Layout title={dict.firm.eyebrow} description={dict.firm.lede}>
  <PageHero eyebrow={dict.firm.eyebrow} heading={dict.firm.heading} lede={dict.firm.lede} />

  <Section container="narrow">
    <div class="prose">
      <h2 class="prose__heading">{dict.firm.missionHeading}</h2>
      <p class="prose__lede">{dict.firm.missionBody}</p>
    </div>
  </Section>

  <Section container="wide" size="sm">
    <figure class="institutional">
      <img
        src="/mockups/library.webp"
        alt="Firm library"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </Section>

  <Section variant="surface">
    <div class="lead-grid">
      <div class="lead-grid__col-label">
        <p class="eyebrow">{dict.firm.valuesHeading}</p>
      </div>
      <div class="lead-grid__col-body">
        <h2 class="lead-grid__heading">Principles that shape every decision.</h2>
      </div>
    </div>

    <ul class="values-grid">
      {dict.firm.values.map((value, i) => (
        <li class="value-card">
          <span class="value-card__index">{String(i + 1).padStart(2, "0")}</span>
          <h3 class="value-card__title">{value.title}</h3>
          <p class="value-card__body">{value.body}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section variant="inverse" container="narrow" size="lg">
    <p class="eyebrow eyebrow--inverse">{dict.firm.architectureHeading}</p>
    <h2 class="architecture__heading">Brand architecture</h2>
    <p class="architecture__body">{dict.firm.architectureBody}</p>
    <div class="architecture__cta">
      <Button href="/en/team" variant="ghost" inverse>Meet the leadership</Button>
    </div>
  </Section>
</Layout>

<style>
  .prose__heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }
  .institutional {
    margin: 0;
    aspect-ratio: 21 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
  }
  .institutional img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .prose__lede {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3.2vw, var(--text-4xl));
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-strong);
    text-wrap: balance;
  }
  .lead-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }
  @media (min-width: 768px) {
    .lead-grid {
      grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
      gap: var(--space-7);
      align-items: baseline;
    }
  }
  .lead-grid__heading {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-strong);
    text-wrap: balance;
  }
  .values-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .value-card {
    padding: var(--space-6);
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .value-card__index {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--color-highlight);
    line-height: 1;
  }
  .value-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    color: var(--color-text-strong);
    line-height: 1.2;
  }
  .value-card__body {
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .architecture__heading {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4.5vw, var(--text-5xl));
    font-weight: var(--weight-regular);
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-inverse);
    margin-block: var(--space-3) var(--space-6);
  }
  .architecture__body {
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    line-height: var(--leading-relaxed);
    color: var(--color-text-inverse-muted);
    max-width: 48rem;
  }
  .architecture__cta {
    margin-top: var(--space-7);
  }
</style>
