---
import { getLocale, t } from "~/i18n/utils";

const locale = getLocale(Astro.url);
const dict = t(locale);
const privacyHref = locale === "pt" ? "/politica-privacidade" : "/en/privacy-policy";
---

<div
  class="cookies"
  role="dialog"
  aria-labelledby="cookies-title"
  aria-describedby="cookies-body"
  data-cookie-banner
  hidden
>
  <div class="cookies__inner container">
    <div class="cookies__copy">
      <h2 id="cookies-title" class="cookies__title">{dict.cookies.title}</h2>
      <p id="cookies-body" class="cookies__body">
        {dict.cookies.body}{" "}
        <a href={privacyHref}>{dict.cookies.managePrivacy}</a>
      </p>
    </div>
    <div class="cookies__actions">
      <button type="button" class="cookies__btn cookies__btn--ghost" data-cookie-essential>
        {dict.cookies.essentialOnly}
      </button>
      <button type="button" class="cookies__btn cookies__btn--accent" data-cookie-accept>
        {dict.cookies.acceptAll}
      </button>
    </div>
  </div>
</div>

<style>
  .cookies {
    position: fixed;
    inset: auto var(--space-4) var(--space-4) var(--space-4);
    z-index: var(--z-toast);
    background: var(--color-bg-inverse);
    color: var(--color-text-inverse);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    padding: var(--space-5);
    animation: cookies-in 0.45s var(--ease-out);
  }

  @media (min-width: 720px) {
    .cookies {
      inset: auto var(--space-6) var(--space-6) auto;
      max-width: 32rem;
    }
  }

  @keyframes cookies-in {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: none;
      opacity: 1;
    }
  }

  .cookies__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: 0;
  }

  .cookies__title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-inverse);
  }

  .cookies__body {
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-text-inverse-muted);
  }

  .cookies__body a {
    color: var(--color-action-inverse);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cookies__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: flex-end;
  }

  .cookies__btn {
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-pill);
    transition: background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .cookies__btn--ghost {
    color: var(--color-text-inverse-muted);
    border: 1px solid var(--color-border-inverse);
    background: transparent;
  }
  .cookies__btn--ghost:hover {
    color: var(--color-text-inverse);
    border-color: var(--color-text-inverse-muted);
  }

  .cookies__btn--accent {
    background: var(--color-action-inverse);
    color: var(--color-action-inverse-text);
    border: 1px solid var(--color-action-inverse);
  }
  .cookies__btn--accent:hover {
    background: var(--color-action-inverse-hover);
    border-color: var(--color-action-inverse-hover);
  }
</style>
