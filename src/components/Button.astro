---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  inverse?: boolean;
  type?: "button" | "submit" | "reset";
  target?: string;
  rel?: string;
  ariaLabel?: string;
  fullWidth?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  inverse = false,
  type = "button",
  target,
  rel,
  ariaLabel,
  fullWidth = false,
  class: className,
} = Astro.props;

const Tag = href ? "a" : "button";
const classes = [
  "btn",
  `btn--${variant}`,
  inverse && "btn--inverse",
  fullWidth && "btn--full",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<Tag
  class={classes}
  href={href}
  type={!href ? type : undefined}
  target={target}
  rel={target === "_blank" ? rel ?? "noopener noreferrer" : rel}
  aria-label={ariaLabel}
>
  <span class="btn__label"><slot /></span>
  <span class="btn__arrow" aria-hidden="true">→</span>
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    border-radius: var(--radius-pill);
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
    text-align: center;
    text-decoration: none;
    cursor: pointer;
  }

  .btn--full {
    width: 100%;
    justify-content: center;
  }

  .btn__arrow {
    display: inline-block;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .btn:hover .btn__arrow {
    transform: translateX(3px);
  }

  .btn:active {
    transform: translateY(1px);
  }

  /* PRIMARY — petrol filled */
  .btn--primary {
    background: var(--color-action);
    color: var(--color-action-text);
    border: 1px solid var(--color-action);
  }
  .btn--primary:hover {
    background: var(--color-action-hover);
    border-color: var(--color-action-hover);
    color: var(--color-action-text);
  }

  /* SECONDARY — outline petrol */
  .btn--secondary {
    background: transparent;
    color: var(--color-text-strong);
    border: 1px solid var(--color-border-strong);
  }
  .btn--secondary:hover {
    background: var(--color-text-strong);
    color: var(--color-action-text);
    border-color: var(--color-text-strong);
  }

  /* GHOST — just label + arrow */
  .btn--ghost {
    background: transparent;
    color: var(--color-text-strong);
    border: none;
    padding-inline: var(--space-2);
  }
  .btn--ghost:hover {
    color: var(--color-action);
  }

  /* Inverse variants (over dark / petrol surfaces) */
  .btn--inverse.btn--primary {
    background: var(--color-action-inverse);
    color: var(--color-action-inverse-text);
    border-color: var(--color-action-inverse);
  }
  .btn--inverse.btn--primary:hover {
    background: var(--color-action-inverse-hover);
    border-color: var(--color-action-inverse-hover);
    color: var(--color-action-inverse-text);
  }
  .btn--inverse.btn--secondary {
    color: var(--color-text-inverse);
    border-color: var(--color-border-inverse);
  }
  .btn--inverse.btn--secondary:hover {
    background: var(--color-text-inverse);
    color: var(--brand-onix);
    border-color: var(--color-text-inverse);
  }
  .btn--inverse.btn--ghost {
    color: var(--color-text-inverse);
  }
  .btn--inverse.btn--ghost:hover {
    color: var(--color-action-inverse);
  }
</style>
