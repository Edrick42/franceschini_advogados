---
import { getLocale, t } from "~/i18n/utils";
const locale = getLocale(Astro.url);
const dict = t(locale);
const privacyHref = locale === "pt" ? "/politica-privacidade" : "/en/privacy-policy";
---

<form class="contact-form" data-contact-form action="/api/contact" method="POST" novalidate>
  <input type="hidden" name="locale" value={locale} />
  <input
    type="text"
    name="botField"
    class="hp"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <div class="row">
    <label class="field">
      <span class="field__label">{dict.contact.formName}</span>
      <input
        type="text"
        name="name"
        autocomplete="name"
        required
        minlength="2"
        maxlength="120"
      />
    </label>
    <label class="field">
      <span class="field__label">{dict.contact.formEmail}</span>
      <input
        type="email"
        name="email"
        autocomplete="email"
        required
        maxlength="160"
      />
    </label>
  </div>

  <div class="row">
    <label class="field">
      <span class="field__label">{dict.contact.formPhone}</span>
      <input
        type="tel"
        name="phone"
        autocomplete="tel"
        maxlength="40"
      />
    </label>
    <label class="field">
      <span class="field__label">{dict.contact.formSubject}</span>
      <input
        type="text"
        name="subject"
        required
        maxlength="160"
      />
    </label>
  </div>

  <label class="field">
    <span class="field__label">{dict.contact.formMessage}</span>
    <textarea
      name="message"
      rows="6"
      required
      minlength="20"
      maxlength="4000"
    ></textarea>
  </label>

  <label class="consent">
    <input type="checkbox" name="consent" required />
    <span>
      {dict.contact.formConsent.split("Política de Privacidade")[0]}
      <a href={privacyHref}>{locale === "pt" ? "Política de Privacidade" : "Privacy Policy"}</a>
      {dict.contact.formConsent.split("Política de Privacidade")[1] ?? ""}
    </span>
  </label>

  <div class="actions">
    <button type="submit" class="submit" data-submit>
      <span data-label-default>{dict.contact.formSubmit}</span>
      <span data-label-loading hidden>{dict.contact.formSubmitting}</span>
    </button>
    <p
      class="status"
      data-status
      role="status"
      aria-live="polite"
      hidden
    ></p>
  </div>
</form>

<script
  is:inline
  define:vars={{
    successMsg: dict.contact.formSuccess,
    errorMsg: dict.contact.formError,
  }}
>
  (function () {
    const form = document.querySelector("[data-contact-form]");
    if (!form) return;
    const submit = form.querySelector("[data-submit]");
    const status = form.querySelector("[data-status]");
    const labelDefault = form.querySelector("[data-label-default]");
    const labelLoading = form.querySelector("[data-label-loading]");

    function setBusy(busy) {
      submit.disabled = busy;
      labelDefault.hidden = busy;
      labelLoading.hidden = !busy;
    }

    function notify(message, ok) {
      status.hidden = false;
      status.textContent = message;
      status.dataset.ok = String(!!ok);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      setBusy(true);
      try {
        const data = new FormData(form);
        const payload = Object.fromEntries(data.entries());
        const res = await fetch(form.action, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error("send failed");
        notify(successMsg, true);
        form.reset();
      } catch (err) {
        notify(errorMsg, false);
      } finally {
        setBusy(false);
      }
    });
  })();
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .hp {
    position: absolute;
    left: -9999px;
    opacity: 0;
    width: 1px;
    height: 1px;
  }

  .row {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  input,
  textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  textarea {
    resize: vertical;
    min-height: 8rem;
    line-height: var(--leading-snug);
  }

  input:focus,
  textarea:focus {
    border-color: var(--color-action);
    outline: none;
  }

  .consent {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .consent input[type="checkbox"] {
    flex-shrink: 0;
    margin-top: 4px;
    accent-color: var(--brand-onix);
    width: 16px;
    height: 16px;
  }

  .consent a {
    color: var(--color-text-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }

  .submit {
    background: var(--color-action);
    color: var(--color-action-text);
    padding: var(--space-4) var(--space-7);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .submit:hover:not(:disabled) {
    background: var(--color-action-hover);
  }

  .submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .status {
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-error);
  }

  .status[data-ok="true"] {
    color: var(--color-success);
  }
</style>
