---
import Logo from "./Logo.astro";
import site from "~/data/site.json";
import { getLocale, t } from "~/i18n/utils";

const locale = getLocale(Astro.url);
const dict = t(locale);
const primary = site.primaryNav[locale];
const secondary = site.secondaryNav[locale];
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <Logo
        shape="wordmark-sub"
        color="cream"
        href={locale === "pt" ? "/" : "/en/"}
        size={120}
      />
      <p class="footer__tagline">{dict.footer.tagline}</p>
    </div>

    <div class="footer__columns">
      <div class="footer__col">
        <h2 class="footer__heading">{dict.contact.eyebrow}</h2>
        <ul class="footer__list">
          <li>
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          </li>
          {
            site.contact.phone && (
              <li>
                <a href={`tel:${site.contact.phoneRaw}`}>{site.contact.phone}</a>
              </li>
            )
          }
        </ul>
      </div>

      <div class="footer__col">
        <h2 class="footer__heading">{dict.contact.addressesHeading}</h2>
        <ul class="footer__list footer__list--addresses">
          {
            site.contact.addresses.map((addr) => (
              <li>
                <span class="footer__city">{addr.city}</span>
                {addr.street && <span class="footer__street">{addr.street}</span>}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__col">
        <h2 class="footer__heading">{dict.nav.menu}</h2>
        <ul class="footer__list">
          {primary.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      {
        (site.social.linkedin || site.social.instagram) && (
          <div class="footer__col">
            <h2 class="footer__heading">Social</h2>
            <ul class="footer__list">
              {site.social.linkedin && (
                <li>
                  <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer">
                    LinkedIn
                  </a>
                </li>
              )}
              {site.social.instagram && (
                <li>
                  <a href={site.social.instagram} target="_blank" rel="noopener noreferrer">
                    Instagram
                  </a>
                </li>
              )}
            </ul>
          </div>
        )
      }
    </div>
  </div>

  <div class="footer__bottom container">
    <p class="footer__rights">
      © {year} {site.legalName}. {dict.footer.rights}
    </p>
    <ul class="footer__meta">
      {secondary.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
      <li>
        <span class="footer__by">
          {dict.footer.by}{" "}
          <a href={dict.footer.byHref} target="_blank" rel="noopener noreferrer">
            {dict.footer.byName}
          </a>
        </span>
      </li>
    </ul>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-inverse);
    color: var(--color-text-inverse);
    padding-block: var(--section-y-sm) var(--space-6);
  }

  .footer__inner {
    display: grid;
    gap: var(--space-8);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
    max-width: 360px;
  }
  .footer__brand :global(.logo img) {
    width: 100%;
    height: auto;
    max-width: 100%;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    color: var(--color-text-inverse-muted);
    line-height: var(--leading-snug);
  }

  .footer__columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  @media (min-width: 640px) {
    .footer__columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .footer__inner {
      grid-template-columns: minmax(0, 1fr) 2fr;
      gap: var(--space-9);
      align-items: start;
    }
    .footer__columns {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-inverse-subtle);
    margin-bottom: var(--space-4);
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: var(--text-sm);
  }

  .footer__list a {
    color: var(--color-text-inverse-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer__list a:hover {
    color: var(--color-text-inverse);
  }

  .footer__list--addresses li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--color-text-inverse-muted);
    font-size: var(--text-sm);
  }

  .footer__city {
    color: var(--color-text-inverse);
    font-weight: var(--weight-medium);
  }

  .footer__bottom {
    margin-top: var(--space-9);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border-inverse);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-text-inverse-subtle);
  }

  .footer__rights {
    line-height: 1.5;
  }

  .footer__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
  }

  .footer__meta a {
    color: var(--color-text-inverse-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer__meta a:hover {
    color: var(--color-text-inverse);
  }

  @media (min-width: 720px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
