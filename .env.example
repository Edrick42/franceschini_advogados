# =============================================================================
# Franceschini Advogados — environment variables
# Copy to .env (dev) and configure in Vercel → Project → Settings → Environment.
# =============================================================================

# GitHub OAuth App (used by Decap CMS auth)
#   Homepage URL:               https://<projeto>.vercel.app
#   Authorization callback URL: https://<projeto>.vercel.app/api/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (transactional email — contact form notifications)
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=contato@franceschiniadvogados.com.br

# Google Analytics 4 measurement ID (e.g., G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID
PUBLIC_CLARITY_ID=

# Canonical site URL (uppercased so it's exposed to client)
PUBLIC_SITE_URL=https://franceschiniadvogados.com.br
